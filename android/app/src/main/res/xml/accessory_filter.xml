<?xml version="1.0" encoding="utf-8"?>
<!--
  USB Accessory filter for Android Open Accessory (AOA) v2 mode.

  When the PC sends AOA SEND_STRING + START_ACCESSORY, the device
  re-enumerates as Google's accessory class device and the platform
  dispatches USB_ACCESSORY_ATTACHED. The system uses these
  manufacturer/model/version triples to decide which app to dispatch
  the intent to.

  These MUST match `AccessoryStrings::default_penflow()` in
  `crates/penflow-transport/src/usb_aoa.rs` byte-for-byte, or the
  intent will go to the chooser dialog instead of straight to us.
-->
<resources>
    <usb-accessory
        manufacturer="Penflow"
        model="Penflow Server"
        version="1.0" />
</resources>
